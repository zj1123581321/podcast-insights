# 复制为 .env 后填写。.env 已被 .gitignore，敏感信息不会进仓库。

# ── 选择处理哪个播客（对应 config/<key>.json）──
PODCAST=feihua

# ── 步骤1：小宇宙 API（拉节目单）──
# refresh token 一次性轮换，刷新成功后旧的立即失效；脚本会把新 token 持久化到
# data/<key>/episodes/.token_state.json。不要与其他在用的服务共用同一 refresh token。
XYZ_REFRESH_TOKEN=
XYZ_ACCESS_TOKEN=
XYZ_DEVICE_ID=

# ── 步骤2/3：VideoTranscriptAPI（提交转录 + 下载校对稿）──
TRANSCRIBE_API_BASE=https://<your-transcribe-host>
TRANSCRIBE_TOKEN=
# 下载校对稿用的 view 基址（公开路由，无需鉴权）；留空则取 TRANSCRIBE_API_BASE
VIEW_API_BASE=

# ── 步骤2 控速（可选，默认值见脚本）──
# CONCURRENCY=2
# POLL_INTERVAL=15
# POLL_TIMEOUT=1800
